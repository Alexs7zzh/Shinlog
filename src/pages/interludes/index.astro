---
import { getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import LanguageSwitcher from '../../components/LanguageSwitcher.astro';
import SidenoteContainer from '../../components/SidenoteContainer.astro';
import { ENTRY_LANGS } from '../../consts';
import { formatHtmlDate, formatReadableDate, formatShortDate } from '../../lib/date';
import {
  getEntryAlternativeLinks,
  getEntryLang,
  getEntryRawSlug,
  stripLanguageSuffix,
  validateEntryLocales,
} from '../../lib/entry-locales';
import { renderMarkdownFragmentWithPrefix } from '../../lib/render-markdown-fragment';
import type { CollectionEntry } from 'astro:content';

type InterludeSource = CollectionEntry<'interludes'>;

function getInterludeSlug(interlude: Pick<InterludeSource, 'id'>): string {
  return stripLanguageSuffix(getEntryRawSlug(interlude));
}

function getCanonicalInterlude(interludes: InterludeSource[]): InterludeSource {
  const baseVariant = interludes.find((interlude) => getEntryRawSlug(interlude) === getInterludeSlug(interlude));
  if (baseVariant) {
    return baseVariant;
  }

  for (const lang of ENTRY_LANGS) {
    const variant = interludes.find((interlude) => getEntryLang(interlude) === lang);
    if (variant) {
      return variant;
    }
  }

  return interludes[0];
}

function sortInterludeVariants(interludes: InterludeSource[], canonical: InterludeSource): InterludeSource[] {
  return [...interludes].sort((left, right) => {
    if (left.id === canonical.id) return -1;
    if (right.id === canonical.id) return 1;

    return ENTRY_LANGS.indexOf(getEntryLang(left)) - ENTRY_LANGS.indexOf(getEntryLang(right));
  });
}

function validateInterludeDates(interludes: InterludeSource[]): void {
  const datesBySlug = new Map<string, string>();

  for (const interlude of interludes) {
    const slug = getInterludeSlug(interlude);
    const date = formatHtmlDate(interlude.data.date);
    const previous = datesBySlug.get(slug);

    if (previous && previous !== date) {
      throw new Error(
        `Interlude locale group "${slug}" must share one date, but found "${previous}" and "${date}" (entry "${interlude.id}").`,
      );
    }

    datesBySlug.set(slug, date);
  }
}

function getInterludeAnchor(interlude: InterludeSource, canonical: InterludeSource): string {
  const date = formatHtmlDate(interlude.data.date);

  return interlude.id === canonical.id ? date : `${date}-${getEntryLang(interlude)}`;
}

const interludes = await getCollection('interludes');

validateEntryLocales(interludes, getInterludeSlug, 'interlude');
validateInterludeDates(interludes);

const interludeGroups = Array.from(
  interludes.reduce((groups, interlude) => {
    const slug = getInterludeSlug(interlude);
    const group = groups.get(slug) ?? [];
    group.push(interlude);
    groups.set(slug, group);
    return groups;
  }, new Map<string, InterludeSource[]>()),
)
  .map(([, variants]) => {
    const canonical = getCanonicalInterlude(variants);
    const entries = sortInterludeVariants(variants, canonical);

    return {
      canonical,
      canonicalAnchor: getInterludeAnchor(canonical, canonical),
      date: canonical.data.date,
      entries,
    };
  })
  .sort((left, right) => left.date.getTime() - right.date.getTime());

const interludesByYear = Array.from(
  interludeGroups.reduce((groups, group) => {
    const year = group.date.getFullYear();
    const yearGroups = groups.get(year) ?? [];
    yearGroups.push(group);
    groups.set(year, yearGroups);
    return groups;
  }, new Map<number, typeof interludeGroups>()),
);

const renderedInterludeGroups = await Promise.all(
  interludeGroups.map(async (group) => {
    const alternative = getEntryAlternativeLinks(
      group.entries,
      getInterludeSlug(group.canonical),
      getInterludeSlug,
      (entry) => `/interludes/#${getInterludeAnchor(entry, group.canonical)}`,
      getEntryLang(group.canonical),
    );
    const entries = await Promise.all(
      group.entries.map(async (entry) => {
        const anchor = getInterludeAnchor(entry, group.canonical);
        const headnoteHtml = entry.data.headnote
          ? await renderMarkdownFragmentWithPrefix(entry.data.headnote, `${anchor}-headnote`)
          : undefined;
        const bodyHtml = entry.body
          ? await renderMarkdownFragmentWithPrefix(entry.body, anchor)
          : '';

        return {
          anchor,
          bodyHtml,
          date: entry.data.date,
          headnoteHtml,
          lang: getEntryLang(entry),
        };
      }),
    );

    return {
      alternative,
      canonicalAnchor: group.canonicalAnchor,
      date: group.date,
      entries,
    };
  }),
);
---

<BaseLayout title="Interludes" htmlLang="en">
  <div class="interlude-index">
    <h2>Index</h2>
    <ol>
      {interludesByYear.map(([year, groups]) => (
        <li class="interlude-index-yearlist">
          <div>{year}:</div>
          <ol>
            {groups.map((group) => (
              <li>
                <a href={`#${group.canonicalAnchor}`} data-astro-prefetch>{formatShortDate(group.date)}</a>
              </li>
            ))}
          </ol>
        </li>
      ))}
    </ol>
  </div>

  <div class="interlude-list">
    {renderedInterludeGroups.map((group, index) => (
      <>
        <div class="interlude-group">
          {group.entries.map((post) => (
            <div
              class="interlude-variant"
              data-interlude-anchor={post.anchor}
              data-default-variant={post.anchor === group.canonicalAnchor ? 'true' : undefined}
            >
              <SidenoteContainer
                className="interlude-item"
                id={post.anchor}
                lang={post.lang}
                afterElements=".interlude-header"
              >
                <header class="interlude-header">
                  <div class="interlude-meta">
                    <time class="interlude-date" datetime={formatHtmlDate(post.date)}>
                      {formatReadableDate(post.date)}
                    </time>
                    <LanguageSwitcher currentLang={post.lang} items={group.alternative} />
                  </div>
                  {post.headnoteHtml && <aside class="interlude-headnote" set:html={post.headnoteHtml} />}
                </header>
                <Fragment set:html={post.bodyHtml} />
              </SidenoteContainer>
            </div>
          ))}
        </div>
        {index < renderedInterludeGroups.length - 1 && <hr />}
      </>
    ))}
  </div>
</BaseLayout>

<style lang="scss">
  @use '../../styles/config';

  .interlude-index {
    padding: calc(var(--spacing) / 4) var(--spacing-half);
    background-color: var(--color-light);
    font-family: var(--ui-font);
    font-weight: 800;
    margin-top: calc(0em - var(--spacing-2));
    margin-bottom: var(--spacing-2);
    margin-left: calc(0em - var(--spacing-half));
    margin-right: calc(0em - var(--spacing-half));
    position: relative;

    @media (--viewport-s) {
      margin-left: 0;
      margin-right: 0;
    }

    h2 {
      font-weight: 500;
      font-size: var(--font);
      color: hsla(360, 89%, 61%, 0.7);
    }

    ol {
      list-style-type: none;
      padding: 0;
      margin: 0;
    }
  }

  .interlude-index-yearlist {
    display: inline;

    div {
      display: inline;
      color: var(--color-mid);
      margin-right: 0.2em;
    }

    ol {
      padding: 0;
      display: inline;
    }

    li {
      display: inline-block;
      position: relative;
      margin-right: 0.5em;

      &::after {
        content: '\A';
        position: absolute;
        top: calc(50% - 0.1em);
        right: -0.35em;
        width: var(--font-xxs);
        height: var(--font-xxs);
        border-radius: 50%;
        background: var(--color-dim);
        opacity: 0.7;
      }

      &:last-child::after {
        display: none;
      }
    }

    a {
      color: var(--color-dim);
      text-decoration: none;

      @media (hover: hover) and (pointer: fine) {
        &:hover {
          color: var(--color-accent-default);
        }
      }
    }
  }

  .interlude-list > hr {
    margin: var(--spacing-2) 0;

    @media (--viewport-m) {
      padding-left: var(--body-padding);
    }
  }

  .interlude-list :global(.interlude-item) {
    display: block;
    position: relative;
  }

  .interlude-list .interlude-variant {
    display: none;
  }

  .interlude-list .interlude-variant[data-default-variant='true'] {
    display: block;
  }

  .interlude-list .interlude-group:has(.interlude-item:target) .interlude-variant {
    display: none;
  }

  .interlude-list .interlude-group .interlude-variant:has(.interlude-item:target) {
    display: block;
  }

  .interlude-list :global(.interlude-item .interlude-header) {
    display: grid;
    gap: var(--spacing-half);
    margin-bottom: var(--spacing-half);
  }

  .interlude-list :global(.interlude-item .interlude-meta) {
    display: grid;
    gap: calc(var(--spacing-half) / 2);
  }

  .interlude-list :global(.interlude-item .interlude-headnote) {
    background-color: var(--color-accent-bg);
    margin: 0;
    padding: calc(var(--line-height) * 0.25) var(--spacing-half);
    line-height: var(--aside-line-height);
    font-family: var(--mono-font);
    font-size: var(--font-s);
    color: var(--color-accent-dim);
  }

  .interlude-list :global(.interlude-item .interlude-headnote)::selection,
  .interlude-list :global(.interlude-item .interlude-headnote ::selection) {
    color: var(--color-bg);
    background-color: var(--color-accent-default);
  }

  .interlude-list :global(.interlude-item .interlude-headnote *:lang(zh)) {
    font-family: var(--mono-font), var(--meta-cjk-zh);
    font-size: var(--font-s);
    line-height: var(--aside-line-height);
  }

  .interlude-list :global(.interlude-item .interlude-headnote *:lang(ja)) {
    font-family: var(--mono-font), var(--meta-cjk-ja);
    font-size: var(--font-s);
    line-height: var(--aside-line-height);
  }

  @media (--viewport-m) {
    .interlude-list :global(.interlude-item) {
      padding-left: var(--body-padding);
    }

    .interlude-list :global(.interlude-item .interlude-header) {
      position: absolute;
      top: 0;
      left: 0;
      width: calc(var(--body-padding) - var(--spacing));
    }
  }

  .interlude-list :global(.interlude-date) {
    display: block;
    font-family: var(--mono-font);
    font-size: var(--font-s);
    user-select: none;
  }

  .interlude-list :global(.interlude-item .switcher) {
    margin-top: calc(var(--spacing-half) / 2);
  }

  @media (--viewport-m) {
    .interlude-list :global(.interlude-date) {
      line-height: var(--line-height);
    }
  }
</style>
