---
import { SITE_TITLE } from '../consts';
import { toUppercaseDisplayText } from '../lib/display-text';

const pathname = Astro.url.pathname;
const navItems = [
  ['Contents', '/'],
  ['Interludes', '/interludes/'],
] as const;
const displaySiteTitle = toUppercaseDisplayText(SITE_TITLE, 'en');
const displayNavItems = navItems.map(([label, href]) => [toUppercaseDisplayText(label, 'en'), href] as const);
---

<h1 class="site-title"><a href="/" data-astro-prefetch>{displaySiteTitle}</a></h1>
<nav>
  {displayNavItems.map(([label, href]) => (
    <a
      class:list={['nav-item', { 'nav-item-active': href === pathname }]}
      href={href}
      data-astro-prefetch
      >{label}</a
    >
  ))}
</nav>

<style lang="scss">
  @use '../styles/config';

  .site-title {
    font-feature-settings: var(--features-latin-bold);
    grid-area: title;
    font-size: var(--font-xl);
    line-height: 1;
    letter-spacing: 0.2em;

    a {
      text-decoration: none;
      color: var(--color-default);
    }

    @media (--viewport-m) {
      font-size: var(--font-l);
    }
  }

  nav {
    grid-area: nav;
    list-style: none;
    padding-left: 0;
    line-height: 1.2; // tricky line height to match site title
    margin: var(--spacing-half) 0;
    font-size: var(--font);
    -webkit-user-select: none;
    user-select: none;

    @media (--viewport-m) {
      font-size: var(--font-l);
      margin: 0;
    }
  }

  .nav-item {
    letter-spacing: 1px;
    margin-right: var(--spacing-half);
    position: relative;
    line-height: 1;
    text-decoration: none;
    color: var(--color-mid);

    &:hover {
      color: var(--color-default);
    }

    &::after {
      content: '\A';
      position: absolute;
      top: calc(50% - var(--font-xxs));
      right: calc(0em - (var(--spacing-half) + var(--font-xxs)) / 2);
      width: var(--font-xxs);
      height: var(--font-xxs);
      border-radius: 50%;
      background: var(--color-accent-default);
      opacity: 0.7;
      display: inline-block;
    }

    &:last-child::after {
      display: none;
    }
  }

  .nav-item-active {
    color: var(--color-default);
  }
</style>
