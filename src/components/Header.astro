---
import { SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname;
const navItems = [
  ['Contents', '/'],
  ['Interludes', '/interludes/'],
];
---

<h1 class="site-title" lang="en"><a href="/" data-astro-prefetch>{SITE_TITLE}</a></h1>
<nav lang="en">
  {navItems.map(([label, href]) => (
    <a
      class:list={['nav-item', { 'nav-item-active': href === pathname }]}
      href={href}
      data-astro-prefetch
    >
      {label}
    </a>
  ))}
</nav>

<style lang="scss">
  @use '../styles/config';

  .site-title {
    grid-area: title;
    font-size: var(--font-xl);
    line-height: 1;
    letter-spacing: 0.2em;

    a {
      text-decoration: none;
      text-transform: uppercase;
      color: var(--color-default);
    }

    @media (--viewport-m) {
      font-size: var(--font-l);
    }
  }

  nav {
    grid-area: nav;
    --nav-gap: var(--spacing-half);
    display: flex;
    gap: var(--nav-gap);
    list-style: none;
    padding-left: 0;
    line-height: 1.2; // tricky line height to match site title
    margin: var(--spacing-half) 0;
    font-size: var(--font);
    -webkit-user-select: none;
    user-select: none;

    @media (--viewport-m) {
      font-size: var(--font-l);
      margin: 0;
    }
  }

  .nav-item {
    text-transform: uppercase;
    letter-spacing: 1px;
    position: relative;
    line-height: 1;
    text-decoration: none;
    color: var(--color-mid);

    &:hover {
      color: var(--color-default);
    }

    &::after {
      content: '\A';
      position: absolute;
      top: 50%;
      inset-inline-end: calc((var(--nav-gap) + var(--font-xxs)) / -2);
      width: var(--font-xxs);
      height: var(--font-xxs);
      transform: translateY(-50%);
      border-radius: 50%;
      background: var(--color-accent-default);
      opacity: 0.7;
      display: inline-block;
    }

    &:last-child::after {
      display: none;
    }
  }

  .nav-item-active {
    color: var(--color-default);
  }
</style>
