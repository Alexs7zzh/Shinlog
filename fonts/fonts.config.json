{
  "defaults": {
    "subsetOptions": {
      "desubroutinize": true,
      "hinting": false,
      "ignoreMissingUnicodes": true
    }
  },
  "jobs": [
    {
      "id": "eb-regular",
      "kind": "body",
      "inputPath": "fonts/source/eb-garamond/EBGaramond-Regular.otf",
      "outputPath": "src/fonts/eb-garamond/eb-garamond-regular.woff2",
      "features": ["ccmp", "kern", "liga", "onum", "calt", "dlig", "cv02", "cv82", "cv90", "locl", "smcp", "sups"],
      "charsetSource": {
        "lang": "en",
        "allRawText": true,
        "alwaysIncludeChars": " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\\\]^_`abcdefghijklmnopqrstuvwxyz{|}~’‘“”–—…⸺•·§❧",
        "selectors": [".site-title", "h2"]
      }
    },
    {
      "id": "eb-italic",
      "kind": "body",
      "inputPath": "fonts/source/eb-garamond/EBGaramond-Italic.otf",
      "outputPath": "src/fonts/eb-garamond/eb-garamond-italic.woff2",
      "features": ["ccmp", "clig", "kern", "liga", "onum", "calt", "dlig", "cv02", "cv82", "locl", "swsh"],
      "charsetSource": {
        "lang": "en",
        "selectors": ["h2", "h3", "em", "i"]
      }
    },
    {
      "id": "eb-semibold",
      "kind": "body",
      "inputPath": "fonts/source/eb-garamond/EBGaramond-SemiBold.otf",
      "outputPath": "src/fonts/eb-garamond/eb-garamond-semibold.woff2",
      "features": ["kern", "liga", "onum", "dlig", "locl", "smcp", "swsh"],
      "charsetSource": {
        "lang": "en",
        "selectors": [".site-title", "h1", "strong", "b", ".init"]
      }
    },
    {
      "id": "ia-duo-regular",
      "kind": "mono",
      "inputPath": "fonts/source/ia-duo/iAWriterDuo-Regular.ttf",
      "outputPath": "src/fonts/ia-duo/ia-writer-duo-regular.woff2",
      "features": [],
      "charsetSource": {
        "lang": "en",
        "alwaysIncludeChars": " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\\\]^_`abcdefghijklmnopqrstuvwxyz{|}~—",
        "selectors": ["time", ".language-label", ".podcast-player-title", ".description", ".interlude-headnote", "code", "pre", "figcaption", ".note", ".footnotes", ".footnote-backref", "[data-footnote-backref]"]
      }
    },
    {
      "id": "ia-duo-italic",
      "kind": "mono",
      "inputPath": "fonts/source/ia-duo/iAWriterDuo-Italic.ttf",
      "outputPath": "src/fonts/ia-duo/ia-writer-duo-italic.woff2",
      "features": [],
      "charsetSource": {
        "lang": "en",
        "selectors": ["em", "i", "code em", "code i", "pre em", "pre i", "figcaption em", "figcaption i", ".note em", ".note i", ".footnotes em", ".footnotes i"]
      }
    },
    {
      "id": "source-han-serif-cn-regular",
      "kind": "cjk",
      "inputPath": "fonts/source/source-han-serif-cn/SourceHanSerifCN-Regular.otf",
      "outputPath": "src/fonts/SourceHanSerifCN/source-han-serif-cn-regular.woff2",
      "features": ["ccmp", "locl", "palt"],
      "excludeFeatures": ["vert", "vrt2", "vkrn"],
      "charsetSource": {
        "alwaysIncludeChars": "⸺〇零一二三四五六七八九十百千万、",
        "langRawText": "zh"
      }
    },
    {
      "id": "source-han-serif-jp-regular",
      "kind": "cjk",
      "inputPath": "fonts/source/source-han-serif-jp/SourceHanSerifJP-Regular.otf",
      "outputPath": "src/fonts/SourceHanSerifJP/source-han-serif-jp-regular.woff2",
      "features": ["ccmp", "locl", "palt"],
      "excludeFeatures": ["vert", "vrt2", "vkrn"],
      "charsetSource": {
        "alwaysIncludeChars": "⸺〇零一二三四五六七八九十百千万、",
        "langRawText": "ja"
      }
    }
  ]
}
