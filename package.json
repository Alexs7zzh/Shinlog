{
  "name": "shinlog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "pnpm fonts",
    "build": "astro build",
    "fonts": "node --experimental-strip-types fonts/build-fonts.ts",
    "typecheck": "astro check",
    "verify:typography:install": "playwright install chromium",
    "verify:typography": "playwright test ./scripts/typography.verify.spec.mjs --config ./scripts/playwright.typography.config.mjs --reporter=line",
    "verify:typography:update": "UPDATE_TYPOGRAPHY_BASELINE=1 playwright test ./scripts/typography.verify.spec.mjs --config ./scripts/playwright.typography.config.mjs --reporter=line",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.1.10",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-smartypants": "^3.0.2",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "node-html-parser": "^7.1.0",
    "postcss": "^8.5.12",
    "postcss-custom-media": "^12.0.1",
    "typescript": "^6.0.3"
  }
}
